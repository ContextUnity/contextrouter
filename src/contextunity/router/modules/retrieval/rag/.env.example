# =============================================================================
# RAG Module Environment Variables
# =============================================================================
# These variables tune the retrieval pipeline. They are optional —
# all have sensible defaults in settings.py.
#
# Copy the ones you need into your service-level .env file.

# ===== Provider =====
# RAG_PROVIDER=brain                      # brain or vertex
# RAG_KG_BACKEND=postgres
# RAG_DB_NAME=                            # "blue", "green", or literal datastore id
# DATA_STORE_ID_BLUE=
# DATA_STORE_ID_GREEN=

# ===== Retrieval Tuning =====
# RAG_CANDIDATE_K=50
# RAG_FINAL_K=8
# RAG_ENABLE_FTS=true
# RAG_HYBRID_VECTOR_WEIGHT=0.8
# RAG_HYBRID_TEXT_WEIGHT=0.2
# RAG_HYBRID_FUSION=weighted              # weighted or rrf
# RAG_RRF_K=60
# RAG_EMBEDDINGS_MODEL=text-embedding-3-small
# RAG_MMR_ENABLED=true
# RAG_MMR_LAMBDA=0.65

# ===== Reranking =====
# RERANKING_ENABLED=false
# RANKER_MODEL=semantic-ranker-512@latest
# RAG_RERANK_PROVIDER=vertex

# ===== Source Limits =====
# MAX_BOOKS=10
# MAX_VIDEOS=10
# MAX_QA=10
# MAX_KNOWLEDGE=5
# GENERAL_RETRIEVAL_ENABLED=false
# GENERAL_RETRIEVAL_INITIAL_COUNT=30
# GENERAL_RETRIEVAL_FINAL_COUNT=15

# ===== Citation Limits =====
# CITATIONS_BOOKS=10
# CITATIONS_VIDEOS=10
# CITATIONS_QA=10
# CITATIONS_WEB=3

# ===== Dual-Read Parity (experimental) =====
# RAG_DUAL_READ_ENABLED=false
# RAG_DUAL_READ_SHADOW_BACKEND=vertex
# RAG_DUAL_READ_SAMPLE_RATE=0.0
# RAG_DUAL_READ_TIMEOUT_MS=300
# RAG_DUAL_READ_LOG_PAYLOADS=false
