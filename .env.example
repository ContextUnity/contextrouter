# =============================================================================
# ContextRouter Environment Configuration
# =============================================================================
# Copy to `.env` and fill in your values.
#
# PRECEDENCE: router.yml > .env > defaults
# SECRETS (API keys, passwords) MUST stay here — never put them in router.yml.
#
# For RAG-specific tuning, see modules/retrieval/rag/.env.example

# ===== Core =====
CU_ROUTER_DEBUG=false
CU_ROUTER_LOG_LEVEL=INFO

# ===== gRPC Server =====
# ROUTER_PORT=50050                      # gRPC listen port
# ROUTER_HOST=0.0.0.0                   # Bind address

# ===== Platform Services =====
# Default ports: Router=50050, Brain=50051, Worker=50052, Zero=50053, Shield=50054
# Override endpoints for remote deployments:
# CU_BRAIN_GRPC_URL=localhost:50051
# CU_WORKER_GRPC_URL=localhost:50052
# CU_ZERO_GRPC_URL=localhost:50053
# CU_SHIELD_GRPC_URL=localhost:50054
REDIS_URL=redis://localhost:6379/0

# ===== Model Selection =====
CU_ROUTER_DEFAULT_LLM=vertex/gemini-2.5-flash
# CU_ROUTER_FALLBACK_LLMS=anthropic/claude-sonnet-4.5,openai/gpt-5-mini
# CU_ROUTER_ALLOW_GLOBAL_FALLBACK=true

# ===== Vertex AI / Google Cloud =====
VERTEX_PROJECT_ID=your-project-id
VERTEX_LOCATION=us-central1
# VERTEX_DISCOVERY_ENGINE_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# ===== External LLM Providers (optional) =====
# OPENAI_API_KEY=sk-...
# OPENAI_REASONING_EFFORT=medium        # minimal, low, medium, high
# ANTHROPIC_API_KEY=sk-ant-...
# PERPLEXITY_API_KEY=pplx-...
# SERPER_API_KEY=...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...
# INCEPTION_API_KEY=...                   # Inception Labs (Mercury-2)
# RUNPOD_API_KEY=...
# HF_TOKEN=hf_...

# ===== Local LLM (vLLM / Ollama) =====
# LOCAL_OLLAMA_BASE_URL=http://localhost:11434
# LOCAL_VLLM_BASE_URL=http://localhost:8000

# ===== Google CSE (optional) =====
# GOOGLE_CSE_ENABLED=false
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=

# ===== Observability =====
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_ENVIRONMENT=development

# ===== Security =====
# CU_PROJECT_SECRET=dev-secret-1234       # For HMAC signing in dev
